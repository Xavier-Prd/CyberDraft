<%# ============================================================ %>
<%# PAGE DRAFT ROUND — Enchères scellées OU Révélation des résultats %>
<%# La vue change selon @is_revelation (les deux joueurs ont validé) %>
<%# ============================================================ %>

<%# Fil d'Ariane %>
<div class="max-w-6xl mx-auto px-8 pt-6">
  <div class="flex items-center gap-2 text-xs text-gray-500 mb-1">
    <%= link_to "Draft", duels_path, class: "hover:text-white transition-colors" %>
    <span>›</span>
    <%= link_to "Duel vs #{@opponent.display_name}", duel_path(@duel), class: "hover:text-white transition-colors" %>
    <span>›</span>
    <span class="text-white">Round <%= @draft_round.round_number %></span>
    <% if @is_revelation %>
      <span>›</span>
      <span class="text-[#f5d800]">Révélation</span>
    <% end %>
  </div>

  <%# Barre de budget + timer %>
  <div class="flex items-center justify-between mb-6 mt-4 bg-[#111627] border border-[#1c2128] rounded px-5 py-3">
    <div class="flex items-center gap-6">
      <div>
        <p class="text-xs text-gray-600 uppercase tracking-widest mb-0.5">Budget restant</p>
        <p class="text-white font-bold text-sm">
          <%= @duel.budget - @engaged_this_round %> ¢
          <span class="text-gray-600 font-normal text-xs">sur <%= @duel.budget %> ¢</span>
          <% if @engaged_this_round > 0 %>
            <span class="text-gray-500 text-xs ml-1">— engagé <%= @engaged_this_round %> ¢ ce tour</span>
          <% end %>
        </p>
      </div>
    </div>

    <div class="text-right">
      <% if @is_revelation %>
        <span class="text-[#f5d800] text-xs font-bold uppercase tracking-widest">● RÉVÉLATION · ROUND <%= @draft_round.round_number %></span>
      <% elsif @draft_round.both_validated? %>
        <span class="text-green-400 text-xs font-bold uppercase tracking-widest">● EN ATTENTE DE RÉVÉLATION</span>
      <% else %>
        <span class="text-pink-400 text-xs font-bold uppercase tracking-widest">● ROUND <%= @draft_round.round_number %> — OUVERT</span>
      <% end %>
    </div>
  </div>
</div>

<% if @is_revelation %>
  <%# ======================================================== %>
  <%# VUE RÉVÉLATION — Résultats des enchères %>
  <%# ======================================================== %>
  <div class="px-8 pb-8 max-w-4xl mx-auto">

    <div class="mb-6">
      <h1 class="text-2xl font-bold text-white uppercase tracking-widest mb-1">Révélation</h1>
      <p class="text-gray-500 text-sm">Round <%= @draft_round.round_number %> — résultats des enchères</p>
    </div>

    <%# Résultats de chaque personnage %>
    <div class="flex flex-col gap-3 mb-6">
      <% @results.sort_by { |r| -r.winning_amount }.each do |result| %>
        <% won_by_me = result.winner == current_user %>

        <%# Carte mise en évidence si le joueur a gagné ce personnage %>
        <div class="bg-[#111627] border <%= won_by_me ? 'border-[#f5d800]' : 'border-[#1c2128]' %> rounded p-5">
          <div class="flex items-center gap-4">

            <%# Avatar du personnage %>
            <div class="w-12 h-12 rounded bg-[#0b0e1a] border <%= won_by_me ? 'border-[#f5d800]' : 'border-gray-700' %> flex items-center justify-center font-bold text-sm flex-shrink-0
                        <%= won_by_me ? 'text-[#f5d800]' : 'text-gray-500' %>">
              <%= result.character.name.gsub(/[^a-zA-Z0-9]/, "").first(2).upcase %>
            </div>

            <%# Nom + univers %>
            <div class="flex-1">
              <p class="text-white font-bold"><%= result.character.name %></p>
              <p class="text-gray-500 text-xs"><%= result.character.universe %> · <%= result.character.recommanded_position %></p>
            </div>

            <%# Flèche + gagnant %>
            <div class="text-right">
              <p class="text-xs text-gray-600 mb-0.5">Adjugé à</p>
              <p class="font-bold text-lg <%= won_by_me ? 'text-[#f5d800]' : 'text-white' %>">
                <%= result.winning_amount %> ¢
              </p>
              <p class="text-xs text-gray-500">
                <%= won_by_me ? "toi" : result.winner.display_name %>
              </p>
            </div>

            <%# Badge tiebreaker si applicable %>
            <% if result.tie_broken_by_time %>
              <span class="text-xs text-gray-500 border border-gray-700 rounded px-2 py-1">
                ⏱ tie-breaker
              </span>
            <% end %>

          </div>
        </div>
      <% end %>

      <%# État vide si pas encore de résultats %>
      <% if @results.empty? %>
        <div class="bg-[#111627] border border-[#1c2128] rounded p-8 text-center">
          <p class="text-gray-600 text-sm italic">Les résultats ne sont pas encore disponibles.</p>
        </div>
      <% end %>
    </div>

    <%# Bouton "Tour suivant" %>
    <%= link_to duel_path(@duel), class: "bg-[#f5d800] text-black font-bold px-8 py-3 rounded uppercase tracking-wide hover:bg-yellow-300 transition-colors" do %>
      Continuer le duel →
    <% end %>

  </div>

<% else %>
  <%# ======================================================== %>
  <%# VUE ENCHÈRES — Lot du tour + panneau de mise %>
  <%# ======================================================== %>
  <div class="px-8 pb-8 max-w-6xl mx-auto grid grid-cols-3 gap-5">

    <%# ---- Colonne gauche (2/3) : liste des personnages disponibles ---- %>
    <div class="col-span-2">

      <div class="flex items-center justify-between mb-4">
        <p class="text-xs text-gray-500 uppercase tracking-widest">
          <%= @available_characters.count %> personnage<%= @available_characters.count > 1 ? "s" : "" %> disponible<%= @available_characters.count > 1 ? "s" : "" %>
        </p>
        <p class="text-xs text-gray-600">Roster : <%= @my_roster_count %> / 10</p>
      </div>

      <%# Filtre par univers %>
      <div class="flex items-center gap-2 mb-4 flex-wrap">
        <% universes = @available_characters.pluck(:universe).uniq.sort %>
        <%= link_to "Tous · #{@available_characters.count}", draft_round_path(@draft_round),
            class: "px-3 py-1 rounded text-xs border transition-colors #{params[:universe].blank? ? 'bg-white text-black border-white' : 'text-gray-400 border-gray-700 hover:border-white'}" %>
        <% universes.each do |univ| %>
          <% count = @available_characters.where(universe: univ).count %>
          <%= link_to "#{univ} · #{count}", draft_round_path(@draft_round, universe: univ),
              class: "px-3 py-1 rounded text-xs border transition-colors #{params[:universe] == univ ? 'bg-white text-black border-white' : 'text-gray-400 border-gray-700 hover:border-white'}" %>
        <% end %>
      </div>

      <%# Liste des personnages %>
      <div class="bg-[#111627] border border-[#1c2128] rounded overflow-hidden">
        <% characters_to_show = params[:universe].present? ? @available_characters.where(universe: params[:universe]) : @available_characters %>

        <% characters_to_show.each_with_index do |character, index| %>
          <%# Vérifie si le joueur a déjà misé sur ce personnage ce round %>
          <% my_bid = @my_bids.find { |b| b.character_id == character.id } %>
          <% already_bid = my_bid.present? %>

          <div class="flex items-center gap-4 px-5 py-4 border-b border-[#1c2128] last:border-0
                       <%= already_bid ? 'bg-[#f5d800]/5 border-l-2 border-l-[#f5d800]' : '' %>">

            <%# Avatar %>
            <div class="w-10 h-10 rounded bg-[#0b0e1a] border border-gray-700 flex items-center justify-center text-[#f5d800] font-bold text-sm flex-shrink-0">
              <%= character.name.gsub(/[^a-zA-Z0-9]/, "").first(2).upcase %>
            </div>

            <%# Nom + univers + poste %>
            <div class="w-44 flex-shrink-0">
              <p class="text-white font-bold text-sm"><%= character.name %></p>
              <p class="text-gray-500 text-xs"><%= character.universe %> · <%= character.recommanded_position %></p>
            </div>

            <%# Stats principales %>
            <div class="flex gap-4 flex-1">
              <% [["ATK", character.strength], ["VIT", character.speed], ["INT", character.intelligence], ["DEF", character.defense]].each do |label, value| %>
                <div class="flex flex-col items-center w-10">
                  <span class="text-gray-600 text-xs"><%= label %></span>
                  <span class="text-white font-bold text-sm"><%= value %></span>
                </div>
              <% end %>
            </div>

            <%# Coût de base comme suggestion %>
            <div class="w-24 text-right flex-shrink-0">
              <p class="text-gray-500 text-xs">Suggérée</p>
              <p class="text-white text-sm font-bold"><%= character.base_cost %> ¢</p>
            </div>

            <%# Bouton : OFFRE SCELLÉE ou Enchérir %>
            <div class="w-36 flex-shrink-0 text-right">
              <% if already_bid %>
                <span class="text-xs font-bold text-[#f5d800] border border-[#f5d800] rounded px-2 py-1 uppercase">
                  ✦ Scellé · <%= my_bid.amount %> ¢
                </span>
              <% elsif !@draft_round.both_validated? %>
                <%# Formulaire d'enchère inline — montant par défaut = coût de base %>
                <%= form_with url: draft_round_bids_path(@draft_round), method: :post, local: true, class: "flex items-center gap-1" do |f| %>
                  <%= f.hidden_field :character_id, value: character.id %>
                  <%= f.number_field :amount, value: character.base_cost, min: 1, max: @duel.budget,
                      class: "w-16 bg-[#0b0e1a] border border-gray-700 rounded px-2 py-1 text-white text-xs text-center focus:border-[#f5d800] outline-none" %>
                  <%= f.submit "Enchérir",
                      class: "bg-[#f5d800] text-black text-xs font-bold px-3 py-1 rounded hover:bg-yellow-300 transition-colors cursor-pointer" %>
                <% end %>
              <% end %>
            </div>

          </div>
        <% end %>

        <% if characters_to_show.empty? %>
          <p class="px-5 py-8 text-gray-600 text-sm italic text-center">
            Aucun personnage disponible.
          </p>
        <% end %>
      </div>

    </div>

    <%# ---- Colonne droite (1/3) : panneau récap enchères ---- %>
    <div class="flex flex-col gap-4">

      <%# Offres scellées ce tour %>
      <div class="bg-[#111627] border border-[#1c2128] rounded p-4">
        <p class="text-xs text-gray-500 uppercase tracking-widest mb-3">Tes offres scellées</p>

        <% if @my_bids.any? %>
          <% @my_bids.each do |bid| %>
            <div class="flex items-center justify-between py-2 border-b border-[#1c2128] last:border-0">
              <div class="flex items-center gap-2">
                <span class="text-[#f5d800] text-xs">✦</span>
                <span class="text-white text-sm font-bold"><%= bid.character.name %></span>
              </div>
              <div class="text-right">
                <span class="text-[#f5d800] font-bold text-sm"><%= bid.amount %> ¢</span>
                <% if bid.submitted_at %>
                  <p class="text-gray-600 text-xs"><%= bid.submitted_at.strftime("%H:%M") %></p>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Total engagé %>
          <div class="flex justify-between pt-2 mt-1 border-t border-[#1c2128]">
            <span class="text-gray-500 text-xs">Engagement total</span>
            <span class="text-white font-bold text-sm"><%= @engaged_this_round %> ¢</span>
          </div>

          <%# Bouton sceller le tour (valider toutes les offres) %>
          <% unless @draft_round.both_validated? %>
            <% already_validated = @duel.home_user == current_user ? @draft_round.home_validate_at.present? : @draft_round.away_validate_at.present? %>
            <% unless already_validated %>
              <%= button_to "Sceller le tour →", validate_draft_round_path(@draft_round),
                  method: :post,
                  class: "w-full mt-4 bg-[#f5d800] text-black font-bold py-3 rounded uppercase tracking-wide hover:bg-yellow-300 transition-colors text-sm" %>
              <p class="text-gray-600 text-xs text-center mt-2">↳ aucune offre visible avant la révélation</p>
            <% else %>
              <div class="mt-4 bg-[#0b0e1a] border border-gray-700 rounded px-4 py-3 text-center">
                <p class="text-green-400 text-xs font-bold">✓ Tour validé</p>
                <p class="text-gray-600 text-xs mt-1">En attente de l'adversaire</p>
              </div>
            <% end %>
          <% end %>

        <% else %>
          <p class="text-gray-600 text-xs italic text-center py-4">
            Aucune offre scellée pour l'instant.
          </p>
        <% end %>
      </div>

      <%# Mon roster en cours de construction %>
      <div class="bg-[#111627] border border-[#1c2128] rounded p-4">
        <p class="text-xs text-gray-500 uppercase tracking-widest mb-3">
          Mon roster · <%= @my_roster_count %> / 10
        </p>
        <% if @my_draft_results.any? %>
          <% @my_draft_results.each do |result| %>
            <div class="flex items-center gap-2 py-1.5 border-b border-[#1c2128] last:border-0">
              <div class="w-7 h-7 rounded bg-[#0b0e1a] border border-gray-700 flex items-center justify-center text-[#f5d800] font-bold text-xs flex-shrink-0">
                <%= result.character.name.gsub(/[^a-zA-Z0-9]/, "").first(2).upcase %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-white text-xs font-bold truncate"><%= result.character.name %></p>
                <p class="text-gray-600 text-xs truncate"><%= result.character.recommanded_position %></p>
              </div>
              <span class="text-gray-500 text-xs"><%= result.winning_amount %> ¢</span>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-600 text-xs italic text-center py-2">Aucun personnage encore.</p>
        <% end %>
      </div>

    </div>

  </div>
<% end %>
