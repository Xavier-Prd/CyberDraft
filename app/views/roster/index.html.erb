<%# ============================================================ %>
<%# PAGE ROSTER — Personnages draftés dans le duel en cours %>
<%# ============================================================ %>

<div class="px-8 py-6 max-w-6xl">

  <%# En-tête %>
  <div class="flex items-start justify-between mb-5">
    <div>
      <p class="text-xs text-gray-600 uppercase tracking-widest mb-1">Mon roster</p>
      <% if @duel %>
        <h1 class="text-2xl font-bold text-white tracking-widest uppercase">
          <%= current_user.display_name.upcase %>
        </h1>
        <p class="text-gray-500 text-sm mt-1">
          <%= @my_characters.count %> personnage<%= @my_characters.count > 1 ? "s" : "" %>
          · <%= @universes.count %> univers
          · VS <%= @opponent.display_name.upcase %>
        </p>
      <% else %>
        <h1 class="text-2xl font-bold text-white tracking-widest uppercase">Aucun duel actif</h1>
      <% end %>
    </div>

    <%# Boutons de tri %>
    <% if @my_characters.any? %>
      <div class="flex gap-2">
        <%= link_to "Trier par coût", roster_path(sort: "cost", universe: params[:universe]),
            class: "px-4 py-1.5 rounded text-xs border transition-colors #{params[:sort] == 'cost' ? 'bg-[#f5d800] text-black border-[#f5d800]' : 'text-gray-400 border-gray-700 hover:border-white hover:text-white'}" %>
        <%= link_to "Trier par nom", roster_path(universe: params[:universe]),
            class: "px-4 py-1.5 rounded text-xs border transition-colors #{params[:sort].blank? ? 'bg-[#f5d800] text-black border-[#f5d800]' : 'text-gray-400 border-gray-700 hover:border-white hover:text-white'}" %>
      </div>
    <% end %>
  </div>

  <% if @duel.nil? %>
    <%# Aucun duel — appel à l'action %>
    <div class="bg-[#111627] border border-[#1c2128] rounded p-12 text-center">
      <p class="text-gray-600 text-sm mb-4">Aucun duel en cours. Lance un défi pour commencer à drafter ton équipe.</p>
      <%= link_to "Nouveau duel →", duels_path, class: "bg-[#f5d800] text-black font-bold px-6 py-3 rounded uppercase text-sm hover:bg-yellow-300 transition-colors" %>
    </div>

  <% elsif @my_characters.empty? %>
    <%# Duel en cours mais aucun personnage encore drafté %>
    <div class="bg-[#111627] border border-[#1c2128] rounded p-12 text-center">
      <p class="text-gray-600 text-sm mb-4">Draft pas encore commencée.</p>
      <%= link_to duel_path(@duel), class: "bg-[#f5d800] text-black font-bold px-6 py-3 rounded uppercase text-sm hover:bg-yellow-300 transition-colors" do %>
        Aller à la draft →
      <% end %>
    </div>

  <% else %>

    <%# Filtres par univers %>
    <div class="flex items-center gap-2 mb-5 flex-wrap">
      <span class="text-xs text-gray-600 uppercase tracking-widest mr-1">Univers</span>

      <%= link_to "Tous · #{@my_characters.count}", roster_path(sort: params[:sort]),
          class: "px-3 py-1 rounded text-xs border transition-colors #{params[:universe].blank? ? 'bg-white text-black border-white' : 'text-gray-400 border-gray-700 hover:border-white'}" %>

      <% @universes.each do |universe| %>
        <% count = @my_characters.count { |c| c.universe == universe } %>
        <%= link_to "#{universe} · #{count}", roster_path(universe: universe, sort: params[:sort]),
            class: "px-3 py-1 rounded text-xs border transition-colors #{params[:universe] == universe ? 'bg-white text-black border-white' : 'text-gray-400 border-gray-700 hover:border-white'}" %>
      <% end %>
    </div>

    <%# Layout 2 colonnes : liste gauche + panneau droit %>
    <div class="grid grid-cols-3 gap-4">

      <%# ---- Liste des personnages (2/3) ---- %>
      <div class="col-span-2">
        <div class="bg-[#111627] border border-[#1c2128] rounded overflow-hidden">
          <% @my_characters.each_with_index do |character, index| %>
            <% usage = @usage[character.id] || 0 %>

            <%= link_to character_path(character),
                class: "flex items-center gap-4 px-5 py-4 border-b border-[#1c2128] last:border-0 hover:bg-[#0b0e1a] transition-colors" do %>

              <%# Avatar %>
              <div class="w-10 h-10 rounded bg-[#0b0e1a] border border-gray-700 flex items-center justify-center text-[#f5d800] font-bold text-sm flex-shrink-0">
                <%= character.name.gsub(/[^a-zA-Z0-9]/, "").first(2).upcase %>
              </div>

              <%# Nom + univers + badge %>
              <div class="w-40 flex-shrink-0">
                <p class="text-white font-bold text-sm"><%= character.name %></p>
                <p class="text-gray-500 text-xs mb-1"><%= character.universe %> · <%= character.recommanded_position %></p>
                <% if usage >= 50 %>
                  <span class="text-xs font-bold text-black bg-[#f5d800] px-1.5 py-0.5 rounded">TRÈS DRAFTÉ</span>
                <% elsif usage >= 20 %>
                  <span class="text-xs font-bold text-black bg-green-400 px-1.5 py-0.5 rounded">POPULAIRE</span>
                <% end %>
              </div>

              <%# Stats %>
              <div class="flex gap-4 flex-1">
                <% [["ATK", character.strength], ["VIT", character.speed], ["INT", character.intelligence], ["DEF", character.defense]].each do |label, value| %>
                  <div class="flex flex-col items-center w-10">
                    <span class="text-gray-600 text-xs"><%= label %></span>
                    <span class="text-white font-bold text-sm"><%= value %></span>
                    <div class="w-full h-0.5 bg-gray-800 rounded mt-0.5">
                      <div class="h-0.5 bg-[#f5d800] rounded" style="width: <%= value %>%"></div>
                    </div>
                  </div>
                <% end %>
              </div>

              <%# Utilisation + coût %>
              <div class="text-right w-20 flex-shrink-0">
                <p class="text-white font-bold"><%= usage %>%</p>
                <p class="text-gray-600 text-xs">utilisation</p>
              </div>

              <div class="text-right w-16 flex-shrink-0">
                <p class="text-white text-sm"><%= character.base_cost %> ¢</p>
                <p class="text-gray-600 text-xs">coût base</p>
              </div>

              <span class="text-gray-500">›</span>

            <% end %>
          <% end %>
        </div>
      </div>

      <%# ---- Panneau droit : synergies + lien vers le duel ---- %>
      <div class="flex flex-col gap-4">

        <%# Synergies par univers %>
        <div class="bg-[#111627] border border-[#1c2128] rounded p-4">
          <p class="text-xs text-gray-500 uppercase tracking-widest mb-3">Synergies d'univers</p>

          <% @synergies.each do |synergie| %>
            <div class="py-2 border-b border-[#1c2128] last:border-0">
              <div class="flex items-center justify-between mb-1">
                <span class="text-white text-sm font-bold">×<%= synergie[:count] %> · <%= synergie[:universe] %></span>
                <% if synergie[:count] >= 2 %>
                  <span class="text-xs font-bold text-green-400 border border-green-400 rounded px-1.5 py-0.5">ACTIF</span>
                <% else %>
                  <span class="text-xs text-gray-600 border border-gray-700 rounded px-1.5 py-0.5">INACTIF</span>
                <% end %>
              </div>
              <% if synergie[:count] >= 2 %>
                <p class="text-gray-400 text-xs">+5% Attaque & Vitesse</p>
              <% else %>
                <p class="text-gray-600 text-xs">manque <%= 2 - synergie[:count] %> perso</p>
              <% end %>
            </div>
          <% end %>
        </div>

        <%# Lien vers le duel actif %>
        <% if @duel.draft? || @duel.match? %>
          <%= link_to duel_path(@duel),
              class: "bg-[#111627] border border-[#f5d800] rounded p-4 text-center hover:bg-[#0b0e1a] transition-colors" do %>
            <p class="text-[#f5d800] text-xs font-bold uppercase tracking-widest mb-1">● DRAFT EN COURS</p>
            <p class="text-white text-sm font-bold">Aller à la draft →</p>
          <% end %>
        <% end %>

      </div>

    </div>

  <% end %>

</div>
