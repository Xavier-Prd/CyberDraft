<!DOCTYPE html>
<html>
  <head>
    <title>Cyber Draft</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cyber Draft">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Police Share Tech Mono depuis Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#0b0e1a] text-white min-h-screen">

    <% if user_signed_in? %>
      <%# ====== SIDEBAR NAVIGATION (visible uniquement si connecté) ====== %>
      <aside class="fixed left-0 top-0 h-screen w-52 bg-[#0b0e1a] border-r border-[#1c2128] flex flex-col z-50">

        <%# Logo en haut %>
        <div class="px-5 py-5 border-b border-[#1c2128]">
          <%= link_to root_path, class: "text-[#f5d800] font-bold text-xs tracking-[0.25em] uppercase hover:opacity-80 transition-opacity" do %>
            CYBER DRAFT
          <% end %>
        </div>

        <%# Liens de navigation %>
        <nav class="flex-1 px-2 py-4 flex flex-col gap-0.5">

          <%# Helper pour savoir si un lien est actif et choisir son style %>
          <% nav_class = ->(active) { "flex items-center px-3 py-2.5 rounded text-sm transition-colors #{active ? 'bg-[#f5d800] text-black font-bold' : 'text-gray-400 hover:text-white hover:bg-[#111627]'}" } %>

          <%= link_to "Accueil", root_path,
              class: nav_class.call(current_page?(root_path)) %>

          <%= link_to "Draft", duels_path,
              class: nav_class.call(request.path.start_with?("/duels")) %>

          <%= link_to "Roster", roster_path,
              class: nav_class.call(current_page?(roster_path)) %>

          <%= link_to "Classement", leaderboard_path,
              class: nav_class.call(current_page?(leaderboard_path)) %>

          <%= link_to "Calendrier", matches_path,
              class: nav_class.call(request.path.start_with?("/matches")) %>

          <%= link_to "Profil", profile_path,
              class: nav_class.call(current_page?(profile_path)) %>

        </nav>

        <%# Section utilisateur en bas de la sidebar %>
        <div class="px-3 py-4 border-t border-[#1c2128] flex items-center gap-3">

          <%# Avatar avec les 2 premières lettres de l'email %>
          <div class="w-8 h-8 rounded bg-[#f5d800] flex items-center justify-center text-black font-bold text-xs flex-shrink-0">
            <%= current_user.initials %>
          </div>

          <%# Nom (préfixe de l'email avant le @) %>
          <p class="text-white text-xs font-bold flex-1 truncate">
            <%= current_user.display_name.upcase %>
          </p>

          <%# Lien de déconnexion %>
          <%= link_to "↩", destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "text-gray-600 hover:text-gray-400 text-sm transition-colors",
              title: "Se déconnecter" %>
        </div>

      </aside>

      <%# Contenu principal décalé de la largeur de la sidebar %>
      <main class="ml-52 min-h-screen">
        <%= yield %>
        <%= render "shared/flashes" %>
      </main>

    <% else %>
      <%# Pas de sidebar pour les visiteurs non connectés %>
      <%= yield %>
      <%= render "shared/flashes" %>
    <% end %>

  </body>
</html>
